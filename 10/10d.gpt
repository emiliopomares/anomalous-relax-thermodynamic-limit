#!/bin/sh
set terminal cairolatex pdf standalone header "\\usepackage{amsfonts}"
set output "10d.tex"

set multiplot

# MAIN --------------------

set label 1 "{\\Large \\textbf{(d)}}" at graph 0.10,0.85 center

set ylabel "{\\huge $a$}"
set xlabel "{\\huge $t_{\\mathrm{w}}$}"
set format x "%.1f"
set ylabel "{\\huge $10^{3} \\times {a_{i}^{m_{\\mathrm{u}}}}$}" offset -2,0
set lmargin 12
set bmargin 4
set xrange [-0.05:0.550]
set yrange [-0.008:0.0032]
set ytics nomirror
set ytics ('-8' -8e-3, '-7' -7e-3, '-6' -6e-3, '-5' -5e-3, '-4' -4e-3, '-3' -3e-3, '-2' -2e-3, '-1' -1e-3, '0' 0e-3, '1' 1e-3, '2' 2e-3, '3' 3e-3, '4' 4e-3, '5' 5e-3)

# 8: clear triangle
# 9: filled triangle
# 4: clear square
# 5: filled square
# 6: clear circle
# 10, 11: down-pointing triangle
# 12, 13: diamond

p "a1_m_jk_x4_0.txt" u ($1-0.0033):2:3 w yerr pt 7 ps 0.25 lc 1 not, \
  "a1_m_jk_x4_0.txt" u ($1-0.0033):2 w points pt 9 ps 1.33 lc 1 not, \
  "a1_m_jk_x4_1.txt" u ($1-0):2:3 w yerr pt 7 ps 0.25 lc 2 not, \
  "a1_m_jk_x4_1.txt" u ($1-0):2 w points pt 9 ps 1.33 lc 2 not, \
  "a1_m_jk_x4_2.txt" u ($1-0.0033):2:3 w yerr pt 7 ps 0.25 lc 3 not, \
  "a1_m_jk_x4_2.txt" u ($1-0.0033):2 w points pt 9 ps 1.33 lc 3 not, \
  "a1_m_jk_x4_3.txt" u ($1-0.0):2:3 w yerr pt 7 ps 0.25 lc 4 not, \
  "a1_m_jk_x4_3.txt" u ($1-0.0):2 w points pt 9 ps 1.33 lc 4 not, \
  "a1_m_jk_x4_4.txt" u ($1-0.0):2:3 w yerr pt 7 ps 0.25 lc 5 not, \
  "a1_m_jk_x4_4.txt" u ($1-0.0):2 w points pt 9 ps 1.33 lc 5 not, \
  "a2_m_jk_x4_0.txt" u ($1-0.0011):2:3 w yerr pt 7 ps 0.25 lc 1 not, \
  "a2_m_jk_x4_0.txt" u ($1-0.0011):2 w points pt 5 ps 1.43 lc 1 not, \
  "a2_m_jk_x4_1.txt" u ($1-0):2:3 w yerr pt 7 ps 0.25 lc 2 not, \
  "a2_m_jk_x4_1.txt" u ($1-0):2 w points pt 5 ps 1.43 lc 2 not, \
  "a2_m_jk_x4_2.txt" u ($1-0.0011):2:3 w yerr pt 7 ps 0.25 lc 3 not, \
  "a2_m_jk_x4_2.txt" u ($1-0.0011):2 w points pt 5 ps 1.43 lc 3 not, \
  "a2_m_jk_x4_3.txt" u ($1-0.0011):2:3 w yerr pt 7 ps 0.25 lc 4 not, \
  "a2_m_jk_x4_3.txt" u ($1-0.0011):2 w points pt 5 ps 1.43 lc 4 not, \
  "a2_m_jk_x4_4.txt" u ($1-0.0011):2:3 w yerr pt 7 ps 0.25 lc 5 not, \
  "a2_m_jk_x4_4.txt" u ($1-0.0011):2 w points pt 5 ps 1.43 lc 5 not, \
  0 lt -1 not

unset label 1
reset

# INSET ---------------

set size 0.50,0.42
set origin 0.475,0.14

set ylabel "{\\large $a$}"
set xlabel "{\\large $t_{\\mathrm{w}}$}"
set format x "%.1f"
set ylabel "{\\large $10^{2} \\times a_{i}^{e_{J} }$}" offset 0,0
set lmargin 12
set bmargin 4
set xrange [-0.05:0.500]
set yrange [-0.05:0.02]
# 9 is filled triangle

set ytics nomirror
set ytics ('-6' -6e-2, '-4' -4e-2, '-2' -2e-2, '0' 0e-2, '2' 2e-2, '4' 4e-2, '6' 6e-2)

s=0.65
p "a1_ej_jk_x4_0.txt" u ($1+0.0):2:3 w yerr pt 7 ps 0.25 lc 1 not, \
  "a1_ej_jk_x4_0.txt" u ($1+0.0):2 w points pt 9 ps (1.33*s) lc 1 not, \
  "a1_ej_jk_x4_1.txt" u ($1+0):2:3 w yerr pt 7 ps 0.25 lc 2 not, \
  "a1_ej_jk_x4_1.txt" u ($1+0):2 w points pt 9 ps (1.33*s) lc 2 not, \
  "a1_ej_jk_x4_2.txt" u ($1+0.0011):2:3 w yerr pt 7 ps 0.25 lc 3 not, \
  "a1_ej_jk_x4_2.txt" u ($1+0.0011):2 w points pt 9 ps (1.33*s) lc 3 not, \
  "a1_ej_jk_x4_3.txt" u ($1+0.0):2:3 w yerr pt 7 ps 0.25 lc 4 not, \
  "a1_ej_jk_x4_3.txt" u ($1+0.0):2 w points pt 9 ps (1.33*s) lc 4 not, \
  "a1_ej_jk_x4_4.txt" u ($1+0.0):2:3 w yerr pt 7 ps 0.25 lc 5 not, \
  "a1_ej_jk_x4_4.txt" u ($1+0.0):2 w points pt 9 ps (1.33*s) lc 5 not, \
  "a2_ej_jk_x4_0.txt" u ($1+0.0033):2:3 w yerr pt 7 ps 0.25 lc 1 not, \
  "a2_ej_jk_x4_0.txt" u ($1+0.0033):2 w points pt 5 ps (1.0*s) lc 1 not, \
  "a2_ej_jk_x4_1.txt" u ($1+0):2:3 w yerr pt 7 ps 0.25 lc 2 not, \
  "a2_ej_jk_x4_1.txt" u ($1+0):2 w points pt 5 ps (1.0*s) lc 2 not, \
  "a2_ej_jk_x4_2.txt" u ($1+0.0033):2:3 w yerr pt 7 ps 0.25 lc 3 not, \
  "a2_ej_jk_x4_2.txt" u ($1+0.0033):2 w points pt 5 ps (1.0*s) lc 3 not, \
  "a2_ej_jk_x4_3.txt" u ($1+0.0033):2:3 w yerr pt 7 ps 0.25 lc 4 not, \
  "a2_ej_jk_x4_3.txt" u ($1+0.0033):2 w points pt 5 ps (1.0*s) lc 4 not, \
  "a2_ej_jk_x4_4.txt" u ($1+0.0033):2:3 w yerr pt 7 ps 0.25 lc 5 not, \
  "a2_ej_jk_x4_4.txt" u ($1+0.0033):2 w points pt 5 ps (1.0*s) lc 5 not, \
  0 lt -1 not

unset multiplot
