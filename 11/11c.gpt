#
# ESTO TIENE EL mismoh y el saltoh mezclados
set terminal cairolatex pdf standalone

v=512.*512
V=v*1500000
meq_hot=0.4970414046986898
ejeq_hot=0.1369965618430244
eteq_hot=-1.8561394709987216
meq_chill=0.5953337085607493
ejeq_chill=0.3813348342429973

etotal_eq = 0.3813348342429973-4.01*0.5953337085607493


# -------- CHANGE OF FILE

set output "11c.tex"


set multiplot

# ---------- MAIN PLOT

set xlabel "{\\LARGE $t$}"
set ylabel "{\\LARGE ${\\langle {{\\mathcal{E}}^{\\perp}}/N \\rangle_{t}}$}" offset -2,0

set label 1 "{\\Large \\textbf{(c)}}" at graph 0.90,0.85 center

###################################### Las dos curvas de energía sin restar eq

set xrange [0:12]
set lmargin 12
set bmargin 4

p "< paste ./curva_EJ_T0.5_h4.01_T0.066_h4.01_1500k.csv ./curva_M_T0.5_h4.01_T0.066_h4.01_1500k.csv ./T0.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) w lines smooth csplines lw 1.5 lt 1 lc rgb "#0030bd" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) w points pt 7 ps 0.35 lt 1 lc rgb "#0030bd" not, \
\
"< paste ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv ./T2.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) w lines smooth csplines lw 1.5 lt 2 lc rgb "#dd1000" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) w points pt 7 ps 0.35 lt 2 lc rgb "#dd1000" not, \
\
  "< paste ./curva_EJ_T0.5_h3.9_T0.066_h4.01_1500k.csv \
        ./curva_M_T0.5_h3.9_T0.066_h4.01_1500k.csv \
        ./T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#40bbff" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#40bbff" not, \
\
  "< paste ./curva_EJ_T2.0_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T2.0_h4.01_T0.066_h4.01_1500k.csv \
        ./T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc 10 not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc 10 not, \
0 lt -1 not

unset label 1

# ---------- INSET

set size 0.55,0.55
set origin 0.4,0.22

set xlabel "{\\large $t$}"
set ylabel "{\\large $10^{5} \\times {\\langle {{\\mathcal{E}}^{\\perp}}/N \\rangle_{t}}$}" offset -2,0

set xrange [3.49949:8]
set yrange [-6.19508e-06:3.6135e-05]
set ytics ('-1' -1e-5, '0' 0, '1' 1e-5, '2' 2e-5, '3' 3e-5)
set lmargin 12
set bmargin 4

p "< paste ./curva_EJ_T0.5_h4.01_T0.066_h4.01_1500k.csv ./curva_M_T0.5_h4.01_T0.066_h4.01_1500k.csv ./T0.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) w lines smooth csplines lw 1.5 lt 1 lc rgb "#0030bd" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) w points pt 7 ps 0.35 lt 1 lc rgb "#0030bd" not, \
\
"< paste ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv ./T2.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) w lines smooth csplines lw 1.5 lt 2 lc rgb "#dd1000" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) w points pt 7 ps 0.35 lt 2 lc rgb "#dd1000" not, \
\
  "< paste ./curva_EJ_T0.5_h3.9_T0.066_h4.01_1500k.csv \
        ./curva_M_T0.5_h3.9_T0.066_h4.01_1500k.csv \
        ./T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#40bbff" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#40bbff" not, \
\
  "< paste ./curva_EJ_T2.0_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T2.0_h4.01_T0.066_h4.01_1500k.csv \
        ./T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc 10 not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc 10 not, \
0 lt -1 not

unset multiplot
reset


