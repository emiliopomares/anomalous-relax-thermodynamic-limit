#
# ESTO TIENE EL mismoh y el saltoh mezclados
set terminal cairolatex pdf standalone
set output "mpemba_dir_mismoh_y_saltoh_m.tex"

v=512.*512
V=v*1500000
meq_hot=0.4970414046986898
ejeq_hot=0.1369965618430244
eteq_hot=-1.8561394709987216
meq_chill=0.5953337085607493
ejeq_chill=0.3813348342429973

etotal_eq = 0.3813348342429973-4.01*0.5953337085607493


# -------- CHANGE OF FILE

set output "11d.tex"


set multiplot

# -------- MAIN PLOT

set label 1 "{\\Large \\textbf{(d)}}" at graph 0.90,0.85 center

set xlabel "{\\LARGE $t$}"
set ylabel "{\\LARGE $\\Delta_t {( {{\\mathcal{E}}^{\\#}} )}$}" offset -2,0


set xrange [0:12]
set lmargin 12
set bmargin 4
p \
"< paste ./curva_EJ_T0.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T0.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv \
        ./T2.5h4.01-_T0.066h4.01_MINUS_T0.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "orange" not, \
"" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)):($13) \
    w points pt 7 ps 0.35 lt 1 lc rgb "orange" not, \
  "< paste ./curva_EJ_T0.5_h3.9_T0.066_h4.01_1500k.csv \
         ./curva_M_T0.5_h3.9_T0.066_h4.01_1500k.csv \
         ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./T2.5h4.01-_T0.066h4.01_MINUS_T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "green" not, \
"" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)):($13) \
    w points pt 7 ps 0.25 lt 1 lc rgb "green" not, \
\
0 lt -1 not
unset label 1

# ---------- INSET
#

set size 0.55,0.55
set origin 0.4,0.22

set xlabel "{\\large $t$}"
set ylabel "{\\large $10^{6} \\times \\Delta_t {( {{\\mathcal{E}}^{\\#}} )}$}" offset -2,0

set xrange [4:9]
set yrange [-2e-5:2e-5]
set lmargin 12
set bmargin 4
set ytics ('-20' -20e-6, '-15' -15e-6, '-10' -10e-6, '-5' -5e-6, '0' 0, '5' 5e-6, '10' 10e-6, '15' 15e-6)
p \
"< paste ./curva_EJ_T0.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T0.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv \
        ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv \
        ./T2.5h4.01-_T0.066h4.01_MINUS_T0.5h4.01-_T0.066h4.01_errors.txt" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "orange" not, \
"" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)):($13) \
    w points pt 7 ps 0.35 lt 1 lc rgb "orange" not, \
"< paste ./curva_EJ_T0.5_h3.9_T0.066_h4.01_1500k.csv \
         ./curva_M_T0.5_h3.9_T0.066_h4.01_1500k.csv \
         ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./T2.5h4.01-_T0.066h4.01_MINUS_T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "green" not, \
"" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)):($13) \
    w points pt 7 ps 0.25 lt 1 lc rgb "green" not, \
"< paste ./curva_EJ_T2.0_h4.01_T0.066_h4.01_1500k.csv \
         ./curva_M_T2.0_h4.01_T0.066_h4.01_1500k.csv \
         ./curva_EJ_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./curva_M_T2.5_h4.01_T0.066_h4.01_1500k.csv \
         ./T2.5h4.01-_T0.066h4.01_MINUS_T0.5h3.9-_T0.066h4.01_errors.txt" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "pink" not, \
"" \
    u 1:(-($2/V-4.01*$5/V)+($8/V-4.01*$11/V)):($13) \
    w points pt 7 ps 0.25 lt 1 lc rgb "pink" not, \
0 lt -1 not
unset label 1


