#
set terminal cairolatex pdf standalone

meq_hot=0.49704133449469673
meq_ini=0.5533598552406073

ejeq_hot=0.13699638971046166
ejeq_ini=0.21362353286995622

set output "8d.tex"

set multiplot

set label 1 "{\\Large \\textbf{(d)}}" at graph 0.10,0.15 center

set label 2 "{\\large $E \\to C$}" at graph 0.60,0.85 center

set label 3 "{\\large $C \\to E$}" at graph 0.30,0.6 center

# ----------------- MAIN PLOT
set size 1,1
set origin 0,0

set lmargin 12
set bmargin 4

set xrange [8:45]
set yrange [-3e-4:15e-5]
set xlabel "{\\LARGE $t$}"
set ylabel "{\\LARGE $10^{4} \\times {\\langle {e_{J}^{\\perp}} \\rangle_{t}}$}" offset -1.5,0
set ytics ('-3' -3e-4, '-2' -2e-4, '-1' -1e-4, '0' 0, '1' 1e-4, '2' 2e-4, '3' 3e-4)
p "./curva_protocol_EJ_T2.5_to_T0.5_1000k_tr.csv" every 6 u 1:($2/(512.*512*1000000)-ejeq_ini):($3/(512.*512)) w yerr pt 0 lc rgb "#dd1000" not, \
  "./curva_protocol_EJ_T0.5_to_T2.5_1000k_tr.csv" every 6 u 1:($2/(512.*512*1000000)-ejeq_hot):($3/(512.*512)) w yerr pt 0 lc rgb "#0030bd" not, \
  0 lt -1 not

unset label 1
unset label 2
unset label 3

# ------------------ INSET
set size 0.45,0.45
set origin 0.5,0.15

set xlabel "$t$"
set ylabel "$10^{5} \\times \\Delta$" offset 0,0
set xrange [24:45]
set yrange [-3e-5:3e-5]
set ytics ('-4' -4e-5, '-2' -2e-5, '0' 0, '2' 2e-5, '4' 4e-5)
plot \
"< paste ./curva_protocol_EJ_T2.5_to_T0.5_1000k_tr.csv ./curva_protocol_EJ_T0.5_to_T2.5_1000k_tr.csv" every 6 \
    u 1:(($2/(512.*512*1000000)-ejeq_ini) - ($5/(512.*512*1000000)-ejeq_hot)):(sqrt( ($3/(512.*512))**2 + ($6/(512.*512))**2 )) w yerr pt 0 lc rgb "dark-grey" not, 0 lt -1 not


unset multiplot
unset label 1
unset label 2
unset label 3
reset
