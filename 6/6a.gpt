########################################
# Parameters
########################################
v     = 512.*512.
norma = v*5.e5
EJ    = 0.21362353286995622

data = "./curve_thermalization_T0.5_EJ_staggered_start_500k_L512.csv"

########################################
# Fit continuous model
########################################
f(x) = exp(-x/tau) * (a1/x**a3) * (1 + a2/x + a4/(x*x) + a5/(x*x*x))

tau = 4.9853
a1  = 0.832839
a2  = -1.25555
a3  = 0.380757
a4  = 3.2327
a5  = 1

fit [5:43.5] f(x) data u 1:(EJ-($2/norma)):($3/v) yerr via tau,a1,a2,a3,a4,a5
fit [5:43.5] f(x) data u 1:(EJ-($2/norma)):($3/v) yerr via tau,a1,a2,a3,a4,a5

########################################
# Fit multi-exponential model
########################################
tau1 = tau

b1   = 0.248584
b2   = 0.5
b3   = 0.1

tau2 = 3.54069
tau3 = 1.3

g(x) = b1*exp(-x/tau1) + b2*exp(-x/tau2) + b3*exp(-x/tau3)

fit [5:43.5] g(x) data u 1:(EJ-($2/norma)):($3/v) yerr via b1,b2,tau3,b3
fit [5:43.5] g(x) data u 1:(EJ-($2/norma)):($3/v) yerr via b1,b2,tau2,tau3,b3
fit [5:43.5] g(x) data u 1:(EJ-($2/norma)):($3/v) yerr via tau1,b1,b2,tau2,tau3,b3

########################################
# Terminal
########################################
set terminal cairolatex pdf standalone size 6,4 \
    header "\\usepackage{amsfonts}"
set output "6a.tex"

########################################
# Formatting
########################################
set lmargin 12
set rmargin 4
set tmargin 2
set bmargin 4

set origin 0.02,0.0

set xlabel "{\\Huge $t$}"
set ylabel "{\\Huge $10^{2} \\times {\\langle {e_{J}}^{\\perp} \\rangle_{t}}$}" offset -2.75,0

set label 1 "{\\Huge \\textbf{(a)}}" at graph 0.90,0.85 center front

########################################
# Ticks
########################################
set ytics ( \
'0' 0, \
'1' 1e-2,  '2' 2e-2,  '3' 3e-2,  '4' 4e-2, \
'5' 5e-2,  '6' 6e-2,  '7' 7e-2,  '8' 8e-2, \
'9' 9e-2,  '10' 10e-2, '11' 11e-2, '12' 12e-2, \
'13' 13e-2, '14' 14e-2, '15' 15e-2, \
'16' 16e-2, '17' 17e-2 )

########################################
# Plot
########################################
plot [5:43.5] \
    data every 20 u 1:(EJ-($2/norma)):($3/v) pt 7 ps 1.25 notitle, \
    f(x) notitle, \
    g(x) notitle, \
    0 lt -1 notitle
