########################################
# Fit and Terminal
########################################
set fit noerrorscaling

set terminal cairolatex pdf standalone header "\\usepackage{amsfonts}"

########################################
# Constants
########################################
ejeq = 0.1369965618430244
meq  = 0.4970414046986898

########################################
# Formatting
########################################
set xlabel "{\\huge $t$}"
set format y "%.2f"

set lmargin 12
set bmargin 4

########################################
# Main plot: $\\langle m_u^\\perp \\rangle_t$
########################################
set output "3b.tex"
set ylabel "{\\huge $10^{2} \\times {\\langle {m}_{\\mathrm{u}}^{\\perp} \\rangle_{t}}$}" offset -2,0
set ytics ('-1' -1e-2, '0' 0e-2, '1' 1e-2, '2' 2e-2, '3' 3e-2, '4' 4e-2, '5' 5e-2, '6' 6e-2, '7' 7e-2, '8' 8e-2)
set yrange [-0.015:0.06]

set multiplot

# --- Full region main plot ---
set origin 0,0
set size 1,1
set label 1 "{\\huge \\textbf{(b)}}" at graph 0.10,0.85 center

plot \
    "curve_M_precooling_tw0.00_3m_L256.csv" every 6 u 1:($2/(256.*256*3000000)-meq):($3/(256.*256)) w points pt 7 ps 0.2 notitle, \
    "curve_M_precooling_tw0.00_750k_L512.csv" every 6 u 1:($2/(512.*512*750000)-meq):($3/(512.*512)) w points pt 7 ps 0.2 notitle, \
    0 lt -1 notitle

unset label 1

# --- Inset ---
reset
set xlabel "$t$"
set size 0.68,0.58
set origin 0.27,0.33

set ylabel "$10^{6} \\times \\Delta$"
set ytics ('-8' -8e-6,'-6' -6e-6,'-4' -4e-6,'-2' -2e-6,'0' 0e-6,'2' 2e-6,'4' 4e-6,'6' 6e-6,'8' 8e-6)

plot "< paste curve_M_precooling_tw0.00_3m_L256.csv curve_M_precooling_tw0.00_750k_L512.csv" every 6 u 1:(($2/(256.*256*3000000)) - ($5/(512.*512*750000))):(sqrt(($3/(256.*256))**2 + ($6/(512.*512))**2)) w yerr pt 7 ps 0.2 notitle, \
     0 lt -1 notitle

# --- Reset before next figure ---
unset multiplot
reset
