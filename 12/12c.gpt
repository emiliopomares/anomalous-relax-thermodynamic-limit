#
set terminal cairolatex pdf standalone

v=512.*512
V=v*1500000
meq_hot=0.4970414046986898
ejeq_hot=0.1369965618430244
eteq_hot=-1.8561394709987216
etotal_eq = 0.1369965618430244-4.01*0.4970414046986898

set output "12c.tex"

#################################################  E TOTAL SIN RESTAR EQ

set multiplot

set label 1 "{\\Large \\textbf{(c)}}" at graph 0.10,0.15 center

# ----------- MAIN PLOT

set xlabel "{\\LARGE $t$}"
set ylabel "{\\LARGE $\\langle {{\\mathcal{E}}^{\\perp}}/N \\rangle_{t}$}" offset -2,0
set format y "%.2f"
set lmargin 12
set bmargin 4
set xrange [0:8]
set yrange [-0.16:0.01]
########### WITH C-SPLINES
p \
"< paste ./curva_EJ_T0.5_h4.01_T2.5_h4.01_1500k.csv \
        ./curva_M_T0.5_h4.01_T2.5_h4.01_1500k.csv \
        ./T0.5h4.01-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#0030bd" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#0030bd" not, \
\
"< paste ./curva_EJ_T0.066_T2.5_1500k.csv \
        ./curva_M_T0.066_T2.5_1500k.csv \
        ./T0.066h4.01-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 2 lc rgb "#dd1000" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 2 lc rgb "#dd1000" not, \
"< paste ./curva_EJ_T0.5_h3.9_T2.5_h4.01_1500k.csv \
        ./curva_M_T0.5_h3.9_T2.5_h4.01_1500k.csv \
        ./T0.5h3.9-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#40bbff" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#40bbff" not, \
\
0 lt -1 not

unset label 1
reset

set size 0.55,0.55
set origin 0.4,0.22

set xlabel "{\\large $t$}"
set ylabel "{\\large $10^{2} \\times {\\langle {{\\mathcal{E}}^{\\perp}}/N \\rangle_{t}}$}" offset -2,0
set lmargin 12
set bmargin 4
set ytics ('-10' -10e-2, '-11' -11e-2, '-12' -12e-2, '-13' -13e-2, '-14' -14e-2, '-15' -15e-2)
set xrange [-0.014246:0.216401]
set yrange [-0.153663:-0.102571]

########### WITH C-SPLINES
set xrange [-0.014812:0.215486]
set yrange [-0.151959:-0.103435]
p \
"< paste ./curva_EJ_T0.5_h4.01_T2.5_h4.01_1500k.csv \
        ./curva_M_T0.5_h4.01_T2.5_h4.01_1500k.csv \
        ./T0.5h4.01-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#0030bd" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#0030bd" not, \
\
"< paste ./curva_EJ_T0.066_T2.5_1500k.csv \
        ./curva_M_T0.066_T2.5_1500k.csv \
        ./T0.066h4.01-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 2 lc rgb "#dd1000" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 2 lc rgb "#dd1000" not, \
"< paste ./curva_EJ_T0.5_h3.9_T2.5_h4.01_1500k.csv \
        ./curva_M_T0.5_h3.9_T2.5_h4.01_1500k.csv \
        ./T0.5h3.9-_T2.5h4.01_errors.txt" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq) \
    w lines smooth csplines lw 1.5 lt 1 lc rgb "#40bbff" not, \
"" \
    u 1:(($2/V-4.01*$5/V)-etotal_eq):($7) \
    w points pt 7 ps 0.25 lt 1 lc rgb "#40bbff" not, \
\
0 lt -1 not


unset multiplot
reset

